# Database URLs
DATA_DB_URL=""
AUTH_DB_URL=""

# Supabase Creds
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_ANON_KEY=""

# Logging Config
LOGGING_CONFIG_PATH=""
LOG_DIR=""
LOG_LEVEL=""

# Ollama
OLLAMA_TIMEOUT=""
OLLAMA_BASE_URL=""
OLLAMA_MODEL=""

# OpenAI
OPENAI_API_KEY=

# LLM provider flags
# COMPARE_RESULTS=true  → call both Ollama + OpenAI in parallel and pick the best response.
#                         Requires both OLLAMA_BASE_URL and OPENAI_API_KEY to be set.
# COMPARE_RESULTS=false → use individual flags below:
#   OLLAMA_FLAG=true    → route requests to Ollama only
#   OPENAI_FLAG=true    → route requests to OpenAI only
#   (both true)         → call both, use the first successful response (no comparison)
COMPARE_RESULTS="false"
OLLAMA_FLAG="false"
OPENAI_FLAG="true"

# Redis Cache
REDIS_URL="redis://localhost:6379"
REDIS_MAX_CONNECTIONS="20"
# TTLs (in seconds) — override defaults if needed
# REDIS_TTL_PROFILE=7200      # 2 hours: personality profile, user profile
# REDIS_TTL_CONFIG=86400      # 24 hours: global/per-user config
# REDIS_TTL_CONVERSATION=1800 # 30 minutes: history, summary, UI state

ENCRYPTION_ENABLED="false"

# GCP KMS (required only when ENCRYPTION_ENABLED=true)
# GCP_PROJECT_ID="your-gcp-project-id"
# GCP_KMS_LOCATION="global"
# GCP_KMS_KEYRING="your-keyring-name"
# GCP_KMS_KEY="your-key-name"
# SERVICE_ACCOUNT_KEY="./config/serviceAccountKey.json"

#Response Generation Flags
#True - calls both Ollama and OpenAI in parallel and returns best option
#False - No Comparison, fall back to other flags
COMPARE_RESULTS=bool

#Fallback Flags for Response Generation
#Set true/false for whichever you want to use for Response Generation Fallback
OPENAI_FLAG=bool 
OLLAMA_FLAG=bool