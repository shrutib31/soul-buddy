# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# Virtual environments
venv/
.venv/
.env/

# All env files with secrets — env vars are injected at runtime via docker-compose env_file
.env
.env.*
!.env.example
.env.demo

# Logs (written at runtime, not baked into the image)
logs/
*.log

# Test & coverage output
tests/
.coverage
coverage.xml

# Build artifacts
dist/
build/

# IDE & OS noise
.vscode/
.idea/
.DS_Store
*.swp
*.bak
*.tmp

# GCP service account key — never bake credentials into the image;
# mount at runtime via a volume or use Workload Identity instead.
config/serviceAccountKey.json

# Dead ML model directory — PyTorch/transformer model removed in favour of
# rule-based classification; directory kept in repo for history but excluded
# from Docker image to keep it clean.
transformer_models/

# Quickstart scripts — for local dev only, not needed in image
quickstart*.sh

# Git
.git/
.gitignore
